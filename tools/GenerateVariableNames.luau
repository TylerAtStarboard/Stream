-- GenerateVariableNames
-- Run in Studio's command bar. Parses all scripts for Stream object creation
-- and maps line numbers to variable names for the Stream debugger

const COMMITTED_SOURCE_ONLY = false



local RunService = game:GetService("RunService")

if RunService:IsRunning() then
	warn("Can't run GenerateStreamDebugNames while in a game session")
	return
end

const CollectionService = game:GetService("CollectionService")
const ScriptEditorService = game:GetService("ScriptEditorService")

const IDENT = "[%a_][%w_]*"

const OUTPUT_NAME = "StreamDebug_VariableNames"

const STREAM_CALLS = {
	"Stream%.Value%(",
	"Stream%.Computed%(",
	"Stream%.Scope%(",
	"Stream%.FromProperty%(",
	"Stream%.FromValueBase%(",
	"Stream%.FromAttribute%(",
	"Stream%.FromInputAction%(",
	":Value%(",
	":Computed%(",
	":InnerScope%(",
	":FromProperty%(",
	":FromValueBase%(",
	":FromAttribute%(",
	":FromInputAction%(",
}

const MONTHS = {
	"January", "February", "March", "April", "May", "June",
	"July", "August", "September", "October", "November", "December",
}

local function getOrdinalSuffix(day: number): string
	if day >= 11 and day <= 13 then return "th" end
	const lastDigit = day % 10
	if lastDigit == 1 then return "st"
	elseif lastDigit == 2 then return "nd"
	elseif lastDigit == 3 then return "rd"
	else return "th" end
end

local function formatTimestamp(): string
	const d = os.date("*t")
	const hour = if d.hour % 12 == 0 then 12 else d.hour % 12
	const ampm = if d.hour >= 12 then "PM" else "AM"
	return string.format(
		"%s %d%s, %d & %d:%02d %s",
		MONTHS[d.month], d.day, getOrdinalSuffix(d.day),
		d.year, hour, d.min, ampm
	)
end

const nameMap = {}
local totalFound = 0
local totalNamed = 0
local totalScripts = 0

const StreamRuntime = game:QueryDescendants("#StreamRuntime")[1]
if not StreamRuntime then
	error("Can't build debug names, stream module not found!")
	return
end

for _, v in game:GetDescendants() do
	if not v:IsA("LuaSourceContainer") then
		continue
	end
	if v == StreamRuntime then
		continue
	end
	local ok, source = pcall(function()
		return if COMMITTED_SOURCE_ONLY then v.Source else ScriptEditorService:GetEditorSource(v)
	end)
	if not ok or not source or source == "" then
		continue
	end

	const scriptPath = v:GetFullName():gsub("^game%.", "")

	const lines = source:split("\n")
	local inBlock = false
	local blockClose = "%]%]"

	for lineNum, line in lines do

		if inBlock then
			if line:find(blockClose) then
				inBlock = false
			end
			continue
		end

		do
			const eqStr = line:match("%-%-%[(=*)%[")
			if eqStr then
				const close = "%]" .. string.rep("=", #eqStr) .. "%]"
				if not line:find(close) then
					inBlock = true
					blockClose = close
				end
				continue
			end
		end

		const code = line:gsub("%-%-.*$", "")

		if code:match("^%s*$") then
			continue
		end

		local hasStream = false
		for _, pattern in STREAM_CALLS do
			if code:find(pattern) then
				hasStream = true
				break
			end
		end
		if not hasStream then
			continue
		end

		totalFound += 1

		const name = code:match("local%s+(" .. IDENT .. ")%s*[,=]")
			or code:match("const%s+(" .. IDENT .. ")%s*[,=]")
			or code:match(IDENT .. "%.(" .. IDENT .. ")%s*=")
			or code:match("^%s*(" .. IDENT .. ")%s*=")

		if name then
			totalNamed += 1
			if not nameMap[scriptPath] then
				nameMap[scriptPath] = {}
				totalScripts += 1
			end
			nameMap[scriptPath][lineNum] = name
		end
	end
end

const existing = StreamRuntime:FindFirstChild(OUTPUT_NAME)
if existing then
	existing:Destroy()
end

const timestamp = formatTimestamp()

const out = {
	string.format("-- Auto-generated by GenerateVariableNames on %s. Do not edit.", timestamp),
	"return {",
}

const sortedPaths = {}
for path in nameMap do
	table.insert(sortedPaths, path)
end
table.sort(sortedPaths)

for _, scriptPath in sortedPaths do
	const lineMap = nameMap[scriptPath]
	table.insert(out, string.format('\t["%s"] = {', scriptPath))

	const sorted = {}
	for ln, nm in lineMap do
		table.insert(sorted, { ln, nm })
	end
	table.sort(sorted, function(a, b)
		return a[1] < b[1]
	end)

	for _, pair in sorted do
		table.insert(out, string.format('\t\t[%d] = "%s",', pair[1], pair[2]))
	end
	table.insert(out, "\t},")
end
table.insert(out, "}")

task.wait(1)

const moduleScript = Instance.new("ModuleScript")
moduleScript.Name = OUTPUT_NAME
moduleScript.Source = table.concat(out, "\n")
moduleScript.Parent = StreamRuntime

print(StreamRuntime:GetFullName(), moduleScript:GetFullName())

print(string.format(
	"GenerateStreamDebugNames: %d calls found, %d named, across %d scripts",
	totalFound, totalNamed, totalScripts
	))
